# ─────────────────────────────────────────────────────────────────
# Lidl Predictor API — Variabili d'ambiente
# Copia come .env e compila TUTTI i valori prima del deploy!
# ─────────────────────────────────────────────────────────────────

# Ambiente: "production" o "development"
APP_ENV=development

# Abilita /docs e /redoc (MAI in production!)
ENABLE_DOCS=true

# Livello log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Porta (Render la imposta automaticamente via $PORT)
PORT=8000

# ── Percorsi file ─────────────────────────────────────────────
MODEL_PATH=models/lidl_predictor_v4.pkl
CSV_PATH=data/lidl_prodotti.csv

# ── Sicurezza pubblica (HMAC) ─────────────────────────────────
# GENERA UNA CHIAVE: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET=CAMBIAMI-con-una-chiave-segreta-lunga

# Età massima firma in secondi (default 60)
SIGNATURE_MAX_AGE_SECONDS=60

# Rate limit per IP al minuto
RATE_LIMIT_PER_MINUTE=60

# ── Sicurezza admin ───────────────────────────────────────────
# GENERA UNA CHIAVE: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=CAMBIAMI-admin-key-segreta

# ── CORS ─────────────────────────────────────────────────────
# Separati da virgola, senza spazi
ALLOWED_ORIGINS=https://tuosito.com,https://www.tuosito.com
